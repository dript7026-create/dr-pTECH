        "precache": false
      },
      {
        "id": "rival_portrait",
        "path": "authoring/clipstudio/portraits/rival.png",
        "usage": "dialogue",
        "precache": false
      }
    ]
  },
  "gameplay": {
    "scenes": [
      {
