        "spawn": [640, 96, 0],
        "logic_components": ["dialogue_actor", "ai_patrol"]
      }
    ],
    "systems": [
      { "name": "delivery_mission_system", "priority": 10, "lifecycle": ["init", "tick", "shutdown"] },
      { "name": "dialogue_system", "priority": 20, "lifecycle": ["init", "tick"] },
      { "name": "economy_system", "priority": 30, "lifecycle": ["init", "tick"] },
      { "name": "courtroom_system", "priority": 40, "lifecycle": ["init", "tick", "shutdown"] }
    ]
  },
  "targets": {
    "clipstudio_bundle": "clipstudio_bundle",
    "blender_bundle": "blender_bundle",
    "idtech2_bundle": "idtech2_bundle"
  }
