    ],
    "ORBKinetics": [
      "compare socket-aligned silhouettes against collision and hit-detection shapes",
      "preserve tighter authored collision intent than decorative overflow"
    ],
    "ORBGlue": [
      "bind generated anchor-node metadata to runtime socket ids",
      "resolve equipment family attachments and animation-state handoff"
    ]
  },
