              "color": "#6c4350",
              "event": "The sanction field demands a precise rooted weave window."
            }
          ]
        },
        "exits": {
          "left": "ossuary_switchyard",
          "right": {
            "room": "ram_gate",
            "requires_room_clear": true
          }
        },
        "bond_weave": {
          "posture_at_most": 26,
          "requires_chorus": "wind_kite",
