      {
        "id": "glasswind_causeway",
        "name": "Glasswind Causeway",
        "safe_room": false,
        "danger": 2,
        "objective": "Stabilize the bridge predators and rescue the Mirror Newt to open reflective routes.",
        "tutorial_tip": "Use Z for melee and X for Glass Beak. Burst commands open posture faster than basic chip damage.",
        "popup": {
          "template": "dialogue_shell",
          "title": "Field Note: Mirror Newt",
          "text": "Mirror Newt is the first explicit rescue reward. The room teaches that route expansion does not come from looting a monster. It comes from calming a living system and earning its trust."
        },
        "palette": [
          "#1e3450",
          "#486e81",
          "#df8a58"
        ],
