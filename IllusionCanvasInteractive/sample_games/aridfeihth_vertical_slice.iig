              "x1": 58,
              "x2": 88,
              "y": 3,
              "color": "#6d7b57"
            }
          ],
          "encounter_zones": [
            {
              "id": "refuge_threshold",
              "x1": 82,
              "x2": 100,
              "pressure_bonus": 0.02,
              "event": "The refuge threshold gives way to the live route."
            }
          ]
        },
        "exits": {
          "right": "choir_stair"
        },
        "enemies": []
      },
      {
        "id": "choir_stair",
        "name": "Choir Stair",
        "safe_room": false,
        "danger": 1,
        "objective": "Practice dodge timing and Chorus control while crossing the exposed stair lane.",
        "tutorial_tip": "Press Space to dodge through pressure and C to toggle Wind Kite. Chorus safety costs bond tension over time.",
        "popup": {
          "template": "tutorial_tip_shell",
          "title": "Pressure Lesson",
          "text": "The Choir Stair introduces a controlled failure space. Wind Kite buys safety, but only if you feel the tension drain and turn Chorus off before it becomes waste."
        },
        "palette": [
          "#1a2535",
