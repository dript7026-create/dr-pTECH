          }
        ]
      },
      {
        "id": "ember_nave",
        "name": "Ember Nave",
        "safe_room": false,
        "danger": 5,
        "objective": "Root the nave sanctioner, sustain Wind Kite, then finish the fight with a full bond weave.",
        "tutorial_tip": "Boss tutorial: lower posture, keep Wind Kite active, make sure the boss is rooted, then press V for Bond Weave.",
        "popup": {
          "template": "death_shell",
          "title": "Boss Resolution",
          "text": "Ember Nave is not solved by damage alone. The sanctioner only yields when the player uses the main room grammar correctly: posture break, rooted window, correct Chorus, then Bond Weave."
        },
        "palette": [
          "#2a2035",
