            }
          ],
          "encounter_zones": [
            {
              "id": "switchyard_lock_zone",
              "x1": 48,
              "x2": 88,
              "pressure_bonus": 0.1,
              "tension_bonus": 0.22,
              "color": "#644352",
              "event": "The switchyard clamps shut until the bailiff is actually broken."
            }
          ]
        },
        "exits": {
          "left": "mirror_cistern",
          "right": {
            "room": "ember_nave",
