      },
      {
        "id": "tutorial_sanctum",
        "name": "Tutorial Sanctum",
        "safe_room": true,
        "danger": 0,
        "objective": "Demo complete. This refuge confirms the full introductory loop: rest, route, fight, rescue, key unlock, boss weave, and return to safety.",
        "tutorial_tip": "You have seen the core loop. From here the next production pass can widen the map and deepen each system.",
        "popup": {
          "template": "save_shell",
          "title": "Sanctum Record",
          "text": "The Tutorial Sanctum is the close of the vertical slice. Save here to preserve the roster, the milestone chain, and the proof that Aridfeihth's opening loop already holds together as authored play."
        },
        "palette": [
          "#273248",
          "#5f6f74",
          "#e1c183"
        ],
        "parallax": [
          {
            "label": "thread altar",
            "x": 36,
            "parallax": 0.26,
            "color": "#5c6b66"
          },
          {
            "label": "sanctum candles",
            "x": 78,
            "parallax": 0.44,
            "color": "#8f7651"
          }
        ],
        "exits": {
          "left": "ram_gate",
          "right": "reliquary_bazaar"
        },
        "enemies": []
      },
      {
        "id": "reliquary_bazaar",
        "name": "Reliquary Bazaar",
        "safe_room": true,
        "danger": 1,
        "objective": "Step into the post-tutorial market lane and preview how later builds can extend the rescue loop into trade, tuning, and roster economy.",
        "tutorial_tip": "The generated merchant shell lands here as a teaser for the next production pass. This room is calm on purpose: it widens the game's horizon after the combat proof.",
        "popup": {
          "template": "merchant_shell",
          "title": "Forward Market",
