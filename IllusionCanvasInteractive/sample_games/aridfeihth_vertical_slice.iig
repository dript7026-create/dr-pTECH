          }
        ],
        "exits": {
          "left": "mirror_cistern",
          "right": "ossuary_switchyard"
        },
        "enemies": []
      },
      {
        "id": "ossuary_switchyard",
        "name": "Ossuary Switchyard",
        "safe_room": false,
        "danger": 4,
        "objective": "Break the switchyard bailiff and push the signal lane open into the ember nave.",
        "tutorial_tip": "Clear-gated exits matter here. The way forward does not open until the active threat is actually neutralized.",
        "popup": {
          "template": "quest_shell",
          "title": "Route Condition",
          "text": "The Switchyard is the tutorial's hard gate. It teaches that route permission is spatial and stateful, not just inventory-based. If the local threat still owns the room, the route does not belong to you."
        },
        "palette": [
          "#251f30",
          "#5e5663",
          "#d98f62"
        ],
        "parallax": [
          {
            "label": "rail bones",
            "x": 18,
