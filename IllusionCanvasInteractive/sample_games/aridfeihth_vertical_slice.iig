{
  "format": {
    "id": "illusioninteractivegame",
    "extension": ".iig",
    "version": "1.0"
  },
  "metadata": {
    "title": "Aridfeihth Tutorial Demo",
    "project": "aridfeihth",
    "engine": "IllusionCanvasInteractive",
    "experience_goal": "A tense side-view tutorial expedition that walks the player through rescue, tension control, boss-state resolution, persistence, and a hinted larger world beyond the first refuge loop."
  },
  "integrations": {
    "egosphere": {
      "mode": "native-preferred",
      "focus": "encounter reading, pressure interpretation, and target emphasis",
      "agent_name": "aridfeihth_field_agent",
      "auto_build": true
    },
    "godai": {
      "difficulty_floor": 0.88,
      "difficulty_ceiling": 1.28,
      "focus": "omen pacing, mercy windows, and encounter escalation"
    },
    "orbengine": {
      "borrowed_capabilities": [
        "parallax layering",
        "pseudo3d floor staging",
        "room-depth composition"
      ]
    },
    "doengine": {
      "borrowed_capabilities": [
        "runtime bucket manifests",
        "deterministic asset intake",
        "automation-ready JSON outputs"
      ]
    }
  },
  "rendering": {
    "style": "2.5D pseudo3D 2D pixel-art hybrid",
    "camera": {
      "mode": "side_view_with_orbstyle_parallax",
      "horizon": 0.56
    },
    "palette_notes": [
      "dry cobalt sky",
      "salt brass highlights",
      "ember rust ground plane"
    ]
  },
  "ui": {
    "skin_manifest": "../generated/ui/illusioncanvas_gothic_ui_skin.json"
  },
  "gameplay": {
    "core_loop": [
      "sortie from refuge",
      "stabilize hostile room",
      "rescue or pacify SimIAM",
      "unlock route or new verb",
      "return to refuge to rest and retune loadout"
    ],
    "combat": {
      "resource": "bond_tension",
      "finisher": "bond_weave",
      "player_identity": "light melee plus pet-directed encounter control"
    },
    "milestones": [
      {
        "id": "refuge_reset",
        "label": "Refuge reset complete",
        "criteria": {
          "rested_in_room": "latchspire_refuge"
        }
      },
      {
        "id": "mirror_newt_rescued",
        "label": "Mirror Newt rescue gate",
        "criteria": {
          "rescued_pet": "mirror_newt",
          "requires_previous": [
            "refuge_reset"
          ]
        }
      },
      {
        "id": "latch_spider_rescued",
        "label": "Latch Spider rescue gate",
        "criteria": {
          "rescued_pet": "latch_spider",
          "requires_previous": [
            "mirror_newt_rescued"
          ]
        }
      },
      {
        "id": "switchyard_stabilized",
        "label": "Switchyard pressure gate cleared",
        "criteria": {
          "room_clear_in_room": "ossuary_switchyard",
          "requires_previous": [
            "latch_spider_rescued"
          ]
        }
      },
      {
        "id": "ember_nave_weave",
        "label": "Boss weave gate resolved",
        "criteria": {
          "boss_defeated_in_room": "ember_nave",
          "requires_previous": [
            "switchyard_stabilized"
          ]
        }
      },
      {
        "id": "sanctum_return",
        "label": "Post-boss return and persistence readiness",
        "criteria": {
          "entered_room": "tutorial_sanctum",
          "requires_previous": [
            "ember_nave_weave"
          ]
        }
      },
      {
        "id": "reliquary_bazaar_reached",
        "label": "Bazaar teaser route reached",
        "criteria": {
          "entered_room": "reliquary_bazaar",
          "requires_previous": [
            "sanctum_return"
          ]
        }
      },
      {
        "id": "atlas_choir_reached",
        "label": "Atlas overlook reached",
        "criteria": {
          "entered_room": "atlas_choir",
          "requires_previous": [
            "reliquary_bazaar_reached"
          ]
        }
      }
    ],
    "persistence": {
      "save_file_suffix": ".save.json",
      "supports_manual_save": true,
      "supports_manual_load": true,
      "notes": "Use F5 to save and F9 to load from the runtime during the vertical slice."
    }
  },
  "world": {
    "start_room": "latchspire_refuge",
    "rooms": [
      {
        "id": "latchspire_refuge",
        "name": "Latchspire Refuge",
        "safe_room": true,
        "danger": 0,
        "objective": "Rest once, review the roster, then leave the refuge with a stable bond profile.",
        "tutorial_tip": "Press R in the refuge to rest. Movement is on the arrow keys. Your first live route begins to the right.",
        "popup": {
          "template": "sanctuary_shell",
          "title": "Refuge Briefing",
          "text": "Latchspire Refuge is the tutorial anchor. Rest now, then step into the route with Glass Beak on Burst and Wind Kite on Chorus so the full system language starts immediately."
        },
        "palette": [
          "#253651",
          "#33556d",
          "#f1ba6b"
        ],
        "parallax": [
          {
            "label": "wind towers",
            "x": 18,
            "parallax": 0.28,
            "color": "#384f68"
          },
          {
            "label": "nursery lanterns",
            "x": 72,
            "parallax": 0.42,
            "color": "#596d55"
          }
        ],
        "layout": {
          "platforms": [
            {
              "id": "refuge_floor",
              "x1": 0,
              "x2": 100,
              "y": 0,
              "color": "#46566b"
            },
            {
