      {
        "id": "scribe_gullet",
        "name": "Scribe Gullet",
        "safe_room": true,
        "danger": 1,
        "objective": "Take a second refuge-style pause, settle bond tension, then move into the switchyard assault.",
        "tutorial_tip": "This is a mid-run calm pocket. Rest again if bond tension is spiking before the next combat gate.",
        "popup": {
          "template": "journal_shell",
          "title": "Journal Insert",
          "text": "The Scribe Gullet is a pacing intervention. It confirms that the route can breathe between rescues and that tension management is an authored rhythm rather than a background stat tax."
        },
        "palette": [
          "#222032",
          "#4d5965",
          "#a7bea2"
        ],
        "parallax": [
          {
            "label": "scribe cages",
