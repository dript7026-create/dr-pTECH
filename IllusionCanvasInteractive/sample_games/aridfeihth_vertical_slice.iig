            }
          }
        ]
      },
      {
        "id": "ram_gate",
        "name": "Ram Gate",
        "safe_room": false,
        "danger": 2,
        "objective": "Use the newly rescued Salt Ram route verb to breach the reliquary barricade and prove the post-boss key loop.",
        "tutorial_tip": "This is the post-boss key test. The route only completes because the boss room gave you Salt Ram.",
        "popup": {
          "template": "choice_shell",
          "title": "Post-Boss Payoff",
          "text": "Ram Gate proves that the boss reward is a spatial verb, not a badge. The tutorial is only complete once the player uses that new companion logic to alter the map immediately."
        },
        "palette": [
          "#23171f",
          "#64505c",
          "#d59e68"
        ],
        "parallax": [
          {
            "label": "gate ribs",
