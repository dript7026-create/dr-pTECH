      {
        "id": "mirror_cistern",
        "name": "Mirror Cistern",
        "safe_room": false,
        "danger": 3,
        "objective": "Read the mirrored attack lines, then free the Latch Spider from the water clocks.",
        "tutorial_tip": "Reed Fin is a Crest pet. Its support is passive, so this room is about noticing what your build is already doing for you.",
        "popup": {
          "template": "codex_shell",
          "title": "Codex: Crest Reading",
          "text": "Mirror Cistern exists to prove that not every pet verb is a button. Reed Fin improves recovery tempo quietly, and the player is expected to notice that passive help while juggling active pressure."
        },
        "palette": [
          "#21354a",
          "#386a6c",
          "#b6dbd8"
        ],
        "parallax": [
