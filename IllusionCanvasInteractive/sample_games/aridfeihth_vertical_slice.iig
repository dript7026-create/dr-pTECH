      {
        "id": "simiam_compact",
        "title": "SimIAM Compact",
        "text": "SimIAMs are not harvested powers. They are companion intelligences whose trust is earned through rescue, stabilization, and habitat care."
      },
      {
        "id": "bond_tension_compact",
        "title": "Bond Tension",
        "text": "Bond tension is the shared stress of expedition and command. Good play is not only survival. It is preserving enough emotional coherence for the roster to keep responding."
      },
      {
        "id": "bond_weave_compact",
        "title": "Bond Weave",
        "text": "Bond Weave is a finisher earned through discipline. It resolves boss states using the same verbs the player has been learning all along."
      }
    ]
  }
